# Jagolink credentials for Next.js server-side scraper
JAGOLINK_USERNAME=
JAGOLINK_PASSWORD=

# Optional backward-compat key for /api/scraper
SCRAPER_API_KEY=

# Required for admin machine force refresh (/api/admin/machines/refresh)
MACHINES_REFRESH_TOKEN=

# Required for background job endpoint (/api/internal/machines/refresh)
# Netlify schedule in this repo (cron is evaluated in UTC):
# - Monday WIB 14:00-22:30 -> */30 7-15 * * 1
# - Tuesday-Thursday WIB 06:00/06:30 -> 0,30 23 * * 1-3
# - Tuesday-Thursday WIB 07:00-22:30 -> */30 0-15 * * 2-4
MACHINE_REFRESH_JOB_TOKEN=

# Refresh window (local hour in MACHINE_REFRESH_TIMEZONE):
# allowed when hour >= START and < END (default: 06:00 - 23:00)
MACHINE_REFRESH_TIMEZONE=Asia/Jakarta
MACHINE_REFRESH_START_HOUR=6
MACHINE_REFRESH_END_HOUR=23

# Required for admin force refresh banner cache (/api/admin/banners/refresh)
# Also used by optional public refresh query: /api/banners/active?refresh=1&token=...
BANNERS_REFRESH_TOKEN=

# Supabase (server-side for now)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Admin session signing key (long random string)
ADMIN_SESSION_SECRET=
